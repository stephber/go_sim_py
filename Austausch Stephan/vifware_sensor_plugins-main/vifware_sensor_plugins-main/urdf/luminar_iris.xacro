<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="Lumimar_Iris">
  <!-- Iris Parameters from Datasheet -->
  <xacro:property name="sensor_length" value="0.106" />
  <xacro:property name="sensor_height" value="0.054" />
  <xacro:property name="sensor_width" value="0.27" />
  <xacro:property name="sensor_mass" value="2.15" />

  <xacro:macro name="Lumimar_Iris" params="*origin parent:=base_link name:=iris">
      <link name="${name}">
          <inertial>
              <mass value="${sensor_mass}"/>
              <origin xyz="0 0 0" rpy="0 0 0 "/>
              <inertia ixx="0.000241148" ixy="0" ixz="0"
                        iyy="0.000241148" iyz="0" izz="0.000264"/>
          </inertial>
          <visual>
              <origin xyz="0 0 0" rpy="0 0 0"/>
              <geometry>
               <!-- <mesh filename="file://$(find vifware_sensor_plugins)/meshes/luminar_iris.dae" />-->
                <box size="${sensor_width} ${sensor_height} ${sensor_length}"/>
              </geometry>
              <material name="Black"/>
          </visual>
      </link>

      <joint name="${name}_mount_joint" type="fixed">
          <xacro:insert_block name="origin" />
          <parent link="${parent}"/>
          <child link="${name}"/>
      </joint>

  </xacro:macro>
</robot>