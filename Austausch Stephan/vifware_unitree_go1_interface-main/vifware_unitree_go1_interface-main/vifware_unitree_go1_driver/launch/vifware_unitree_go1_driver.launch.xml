<?xml version="1.0"?>
<launch>

  <!-- vehicle info -->
  <arg name="vifware_unitree_go1_param_file" default="$(find-pkg-share vifware_unitree_go1_driver)/config/unitree_go1_driver.param.yaml"/>
  <arg name="use_sim_time" default="false"/>

  <node pkg="unitree_legged_real" exec="udp_high" output="screen">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
    <remap from="high_cmd" to="/vehicle/high_cmd"/>
    <remap from="high_state" to="/vehicle/high_state"/>

  </node>

  <node pkg="unitree_legged_real" exec="jsp_high" output="screen">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
    <remap from="joint_states" to="/joint_states"/>
    <remap from="high_state" to="/vehicle/high_state"/>
  </node>

  <node pkg="vifware_unitree_go1_driver" exec="vifware_unitree_go1_driver" output="screen">
    <param from="$(var vifware_unitree_go1_param_file)" />
    <param name="use_sim_time" value="$(var use_sim_time)"/>
  </node>

</launch>
